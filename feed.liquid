---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?><feed xmlns="http://www.w3.org/2005/Atom"><generator uri="https://www.11ty.dev/" version="3.1.5">Eleventy</generator><link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml" /><link href="{{ site.url }}/" rel="alternate" type="text/html" /><updated>{{ collections.posts | getNewestCollectionItemDate | dateToRfc3339 }}</updated><id>{{ site.url }}/feed.xml</id><title type="html">{{ site.title }}</title><subtitle>{{ site.description }}</subtitle>{%- for post in collections.posts | reverse -%}<entry><title type="html">{{ post.data.title }}</title><link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html" title="{{ post.data.title }}" /><published>{{ post.date | dateToRfc3339 }}</published><updated>{{ post.date | dateToRfc3339 }}</updated><id>{{ site.url }}{{ post.url | replace: "/$", "" }}</id><content type="html" xml:base="{{ site.url }}{{ post.url }}"><![CDATA[{{ post.templateContent }}]]></content><author><name></name></author>{%- if post.data.category %}<category term="{{ post.data.category }}" />{%- endif -%}{%- for tag in post.data.tags %}<category term="{{ tag }}" />{%- endfor -%}<summary type="html"><![CDATA[{{ post.data.title }}]]></summary></entry>{%- endfor -%}</feed>
